# Android local
ANDROID_DEVICE_NAME=emulator-5554
ANDROID_PLATFORM_VERSION=13.0
ANDROID_AVD_NAME=Pixel_6_API_33

# Credenciais de teste: substitua pelos valores do seu ambiente
# (nunca commitar o .env real)
TEST_USER_EMAIL=<seu-email-de-teste>
TEST_USER_PASSWORD=<sua-senha-de-teste>
TEST_SIGNUP_EMAIL=<email-para-cadastro>
TEST_SIGNUP_PASSWORD=<senha-para-cadastro>

# BrowserStack (credenciais em app-automate.browserstack.com/dashboard)
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=

# Preenchido pelo script bs:upload:android.
# Se já hospedou o app manualmente, cole a URL bs:// aqui.
BROWSERSTACK_APP_ANDROID=
